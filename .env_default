# ─────────────────────────────────────────────────────────────
#  Rulezet — environment variables template
#  Copy this file to .env and fill in the values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-very-secret-key-here

# ── Server binding ────────────────────────────────────────────
# Host and port the Flask dev server / gunicorn listens on.
# Default: 127.0.0.1:7009
#FLASK_URL=127.0.0.1
#FLASK_PORT=7009

# ── Public URL (optional) ─────────────────────────────────────
# The URL your instance is reachable at from the internet.
# Used in telemetry pings so the community registry shows the right address.
# If unset, http://FLASK_URL:FLASK_PORT is used.
#INSTANCE_PUBLIC_URL=https://myinstance.example.com

# ── Email (optional — needed for account verification) ────────
#MAIL_SERVER=smtp.gmail.com
#MAIL_PORT=587
#MAIL_USE_TLS=true
#MAIL_USE_SSL=false
#MAIL_USERNAME=your-email@gmail.com
#MAIL_PASSWORD=your-app-password
#MAIL_DEFAULT_SENDER=your-email@gmail.com

